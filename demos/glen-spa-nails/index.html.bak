<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Glen Spa Nails | Glenview, IL</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Jost',sans-serif;background:#faf8f5;color:#2a2218;overflow-x:hidden}
/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1.4rem 3rem;mix-blend-mode:normal;background:rgba(250,248,245,0.92);backdrop-filter:blur(8px);border-bottom:1px solid rgba(180,155,120,0.2)}
.logo{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:300;letter-spacing:0.12em;text-decoration:none;color:#2a2218;font-style:italic}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{text-decoration:none;font-size:0.72rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;color:#888;transition:color 0.2s}
.nav-links a:hover{color:#2a2218}
.nav-book{background:#2a2218;color:#faf8f5 !important;padding:0.5rem 1.4rem}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer}
.hamburger span{width:20px;height:1px;background:#2a2218}
@media(max-width:768px){.nav-links{display:none;position:fixed;inset:0;background:#faf8f5;flex-direction:column;justify-content:center;align-items:center;gap:2rem}.nav-links.open{display:flex}.hamburger{display:flex;z-index:200}}

/* HERO — full bleed split */
.hero{display:grid;grid-template-columns:1fr 1fr;min-height:100vh}
@media(max-width:768px){.hero{grid-template-columns:1fr;grid-template-rows:50vh auto}}
.hero-img{position:relative;overflow:hidden}
.hero-img img{width:100%;height:100%;object-fit:cover}
.hero-text{display:flex;flex-direction:column;justify-content:center;padding:8rem 5rem 4rem 5rem;background:#faf8f5}
@media(max-width:768px){.hero-text{padding:3rem 2rem}}
.hero-eyebrow{font-size:0.65rem;font-weight:500;letter-spacing:0.35em;text-transform:uppercase;color:#b49b78;margin-bottom:1.5rem}
.hero-text h1{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,6vw,5rem);font-weight:300;line-height:1.1;margin-bottom:1.5rem}
.hero-text h1 em{font-style:italic;color:#b49b78}
.hero-text p{font-size:0.9rem;color:#888;line-height:1.9;max-width:360px;margin-bottom:3rem;font-weight:300}
.btn-dark{display:inline-block;background:#2a2218;color:#faf8f5;padding:1rem 2.5rem;font-size:0.72rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;transition:background 0.2s}
.btn-dark:hover{background:#4a3c2e}
.btn-outline-dark{display:inline-block;border:1px solid #2a2218;color:#2a2218;padding:1rem 2.5rem;font-size:0.72rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;text-decoration:none;transition:all 0.2s;margin-left:1rem}
.btn-outline-dark:hover{background:#2a2218;color:#faf8f5}
.hero-badges{display:flex;flex-wrap:wrap;gap:1rem;margin-top:2.5rem}
.badge{font-size:0.68rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:#b49b78;display:flex;align-items:center;gap:0.4rem}
.badge::before{content:'';width:16px;height:1px;background:#b49b78}

/* SERVICES — horizontal scroll strip */
.services-strip{background:#2a2218;padding:3rem 0;overflow:hidden}
.services-inner{display:flex;gap:0;white-space:nowrap}
.service-tile{flex:0 0 280px;padding:2.5rem 2.5rem;border-right:1px solid rgba(255,255,255,0.08);white-space:normal}
.service-tile h3{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:400;color:#e8dcc8;margin-bottom:0.6rem;font-style:italic}
.service-tile p{font-size:0.78rem;color:rgba(232,220,200,0.5);line-height:1.7}
.service-tile .price{font-size:1.1rem;font-weight:300;color:#b49b78;margin-top:1rem}

/* ABOUT — editorial offset */
.about{display:grid;grid-template-columns:5fr 4fr;gap:0;min-height:500px}
@media(max-width:768px){.about{grid-template-columns:1fr}}
.about-imgs{display:grid;grid-template-columns:1fr 1fr;gap:4px}
.about-imgs img{width:100%;height:100%;object-fit:cover;display:block}
.about-imgs .tall{grid-row:span 2}
.about-copy{padding:5rem 4rem;display:flex;flex-direction:column;justify-content:center;background:#f0ede8}
@media(max-width:768px){.about-copy{padding:3rem 2rem}}
.section-label{font-size:0.62rem;font-weight:500;letter-spacing:0.35em;text-transform:uppercase;color:#b49b78;margin-bottom:1.2rem}
.about-copy h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,4vw,3rem);font-weight:300;line-height:1.2;margin-bottom:1.5rem}
.about-copy p{font-size:0.85rem;color:#777;line-height:1.9;margin-bottom:1rem;font-weight:300}

/* GALLERY — masonry feel */
.gallery{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:220px;gap:4px}
@media(max-width:768px){.gallery{grid-template-columns:1fr 1fr}}
.gallery img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.4s;filter:brightness(0.9)}
.gallery img:hover{transform:scale(1.03);filter:brightness(1)}
.gallery .wide{grid-column:span 2}

/* HOURS */
.hours-section{display:grid;grid-template-columns:1fr 1fr}
@media(max-width:768px){.hours-section{grid-template-columns:1fr}}
.hours-img{position:relative;overflow:hidden;min-height:400px}
.hours-img img{width:100%;height:100%;object-fit:cover;filter:brightness(0.7)}
.hours-img-text{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:3rem;background:linear-gradient(to top,rgba(42,34,24,0.8),transparent)}
.hours-img-text h2{font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:300;color:#fff;font-style:italic}
.hours-panel{background:#2a2218;padding:5rem 4rem;color:#e8dcc8}
@media(max-width:768px){.hours-panel{padding:3rem 2rem}}
.hours-panel .section-label{color:#b49b78}
.hours-panel h2{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;margin-bottom:2rem;font-style:italic}
.hour-row{display:flex;justify-content:space-between;padding:0.8rem 0;border-bottom:1px solid rgba(255,255,255,0.07);font-size:0.85rem}
.hour-row:last-of-type{border:none}
.hour-day{color:rgba(232,220,200,0.5);font-weight:300}
.hour-time{color:#e8dcc8;font-weight:400}
.contact-line{font-size:0.85rem;color:rgba(232,220,200,0.55);margin-top:0.6rem;display:flex;align-items:center;gap:0.6rem}
.contact-line a{color:#b49b78;text-decoration:none}
.divider-line{width:30px;height:1px;background:#b49b78;margin:2rem 0}
iframe{width:100%;height:220px;border:none;margin-top:1.5rem;filter:grayscale(50%) sepia(20%)}
footer{background:#1a1410;text-align:center;padding:2.5rem;font-size:0.75rem;color:#555}
footer span{color:#b49b78}
</style>
</head>
<body>
<nav>
  <a href="#" class="logo">Glen Spa Nails</a>
  <button class="hamburger" onclick="document.querySelector('.nav-links').classList.toggle('open')"><span></span><span></span><span></span></button>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#hours">Hours</a></li>
    <li><a href="tel:" class="nav-book">Book Now</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="hero-img">
    <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=900&q=80" alt="Nail salon">
  </div>
  <div class="hero-text">
    <p class="hero-eyebrow">Glenview's Premier Nail Spa</p>
    <h1>Where nails<br>become <em>art.</em></h1>
    <p>A relaxing escape in the heart of Glenview. Premium nail care, expert technicians, and a space designed for you to unwind.</p>
    <div><a href="#services" class="btn-dark">Our Services</a><a href="#hours" class="btn-outline-dark">Visit Us</a></div>
    <div class="hero-badges">
      <span class="badge">Walk-ins Welcome</span>
      <span class="badge">Appointments Available</span>
      <span class="badge">Gift Cards</span>
    </div>
  </div>
</section>

<div class="services-strip">
  <div class="services-inner" id="services">
    <div class="service-tile"><h3>Manicure</h3><p>Classic, gel, dip powder, and more. Perfectly shaped and polished every time.</p><div class="price">from $25</div></div>
    <div class="service-tile"><h3>Pedicure</h3><p>Relaxing soak, exfoliation, and polish. Leave with silky smooth feet.</p><div class="price">from $35</div></div>
    <div class="service-tile"><h3>Nail Art</h3><p>Custom designs, chrome, ombre, and intricate hand-painted art.</p><div class="price">from $15</div></div>
    <div class="service-tile"><h3>Acrylic & Gel</h3><p>Full sets, fills, and extensions for length and strength.</p><div class="price">from $45</div></div>
    <div class="service-tile"><h3>Waxing</h3><p>Brow shaping, lip, chin, and full face waxing services.</p><div class="price">from $12</div></div>
    <div class="service-tile"><h3>Packages</h3><p>Mani + pedi combos and spa packages for the full experience.</p><div class="price">from $60</div></div>
  </div>
</div>

<section class="about" id="about">
  <div class="about-imgs">
    <img class="tall" src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=600&q=80" alt="Nail art">
    <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=400&q=80" alt="Salon interior">
    <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=400&q=80" alt="Nail polish">
  </div>
  <div class="about-copy">
    <p class="section-label">About Us</p>
    <h2>More than a nail salon — a sanctuary.</h2>
    <p>Glen Spa Nails was built around one idea: every client deserves to be treated exceptionally. From the moment you walk in, we make sure your experience is relaxing, personal, and worth every minute.</p>
    <p>Our team of skilled technicians stays up to date with the latest trends and techniques — from classic polish to intricate nail art. We use only premium products and maintain the highest sanitation standards.</p>
    <a href="#hours" class="btn-dark" style="margin-top:1.5rem;align-self:flex-start">Come Visit Us</a>
  </div>
</section>

<div class="gallery">
  <img class="wide" src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=900&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=500&q=80" alt="">
</div>

<section class="hours-section" id="hours">
  <div class="hours-img">
    <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=800&q=80" alt="">
    <div class="hours-img-text"><h2>Find us in Glenview.</h2></div>
  </div>
  <div class="hours-panel">
    <p class="section-label">Visit Us</p>
    <h2>Hours & Location</h2>
    <div class="hour-row"><span class="hour-day">Monday – Friday</span><span class="hour-time">10:00 AM – 7:30 PM</span></div>
    <div class="hour-row"><span class="hour-day">Saturday</span><span class="hour-time">9:00 AM – 6:00 PM</span></div>
    <div class="hour-row"><span class="hour-day">Sunday</span><span class="hour-time">11:00 AM – 5:00 PM</span></div>
    <div class="divider-line"></div>
    <div class="contact-line">📍 Glenview, IL 60025</div>
    <div class="contact-line">📞 <a href="tel:">(847) 000-0000</a></div>
    <div class="contact-line">Walk-ins welcome · Appointments preferred</div>
    <iframe src="https://www.google.com/maps/embed/v1/place?key=AIzaSyD-9tSrke72PouQMnMX-a7eZSW0jkFmBWY&q=Glenview,IL+60025" allowfullscreen loading="lazy"></iframe>
  </div>
</section>

<footer><span>Glen Spa Nails</span> · Glenview, IL · Walk-ins Welcome · © 2025</footer>
</body>
</html>
