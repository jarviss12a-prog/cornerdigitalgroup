<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Glen Spa Nails | Glenview, IL</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:#fff;color:#111;overflow-x:hidden}
/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 2rem;height:64px;display:flex;align-items:center;justify-content:space-between;background:#fff;border-bottom:2px solid #111}
.logo{font-family:'Bebas Neue',cursive;font-size:1.5rem;letter-spacing:0.1em;text-decoration:none;color:#111}
.logo span{color:#e75480}
.nav-links{display:flex;gap:0;list-style:none}
.nav-links a{text-decoration:none;font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#111;padding:0.5rem 1.2rem;transition:all 0.15s;border-left:2px solid #111}
.nav-links a:hover{background:#111;color:#fff}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer}
.hamburger span{width:22px;height:2px;background:#111}
@media(max-width:768px){.nav-links{display:none;position:fixed;inset:0;background:#fff;flex-direction:column;justify-content:center;align-items:flex-start;gap:0;padding:3rem}.nav-links.open{display:flex}.nav-links a{border:none;border-bottom:2px solid #111;width:100%;font-size:1.2rem;padding:1rem 0}.hamburger{display:flex;z-index:200}}

/* HERO — full screen with big type overlay */
.hero{position:relative;height:100vh;min-height:600px;display:flex;flex-direction:column}
.hero-bg img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top}
.hero-top-bar{position:relative;z-index:2;background:#e75480;padding:0.6rem 2rem;display:flex;align-items:center;justify-content:space-between;margin-top:64px}
.hero-top-bar span{font-size:0.68rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#fff}
.hero-main{position:relative;z-index:2;flex:1;display:flex;align-items:flex-end;padding:0 2rem 3rem}
.hero-title-block{background:#fff;padding:2rem 2.5rem;max-width:480px;border-top:4px solid #e75480}
.hero-title-block h1{font-family:'Bebas Neue',cursive;font-size:clamp(3rem,8vw,5.5rem);line-height:0.92;letter-spacing:0.03em;margin-bottom:0.8rem}
.hero-title-block h1 span{color:#e75480}
.hero-title-block p{font-size:0.85rem;color:#555;line-height:1.7;margin-bottom:1.5rem;font-weight:300}
.hero-btns{display:flex;gap:0}
.btn-black{background:#111;color:#fff;padding:0.9rem 2rem;font-size:0.72rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;border:2px solid #111;transition:all 0.2s}
.btn-black:hover{background:transparent;color:#111}
.btn-pink{background:#e75480;color:#fff;padding:0.9rem 2rem;font-size:0.72rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;border:2px solid #e75480;transition:all 0.2s}
.btn-pink:hover{background:transparent;color:#e75480}

/* SERVICES — numbered list style */
.services{padding:4rem 2rem;border-top:2px solid #111;border-bottom:2px solid #111}
.services-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem}
.services-header h2{font-family:'Bebas Neue',cursive;font-size:clamp(2.5rem,6vw,4rem);letter-spacing:0.05em}
.services-header a{font-size:0.72rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#e75480;text-decoration:none}
.service-list{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-left:2px solid #111}
@media(max-width:768px){.service-list{grid-template-columns:1fr}}
.service-item{padding:2rem;border-right:2px solid #111;border-bottom:2px solid #111}
@media(max-width:768px){.service-item{border-right:none}}
.service-num{font-family:'Bebas Neue',cursive;font-size:3rem;color:#e5e5e5;line-height:1;margin-bottom:0.3rem}
.service-item h3{font-family:'Bebas Neue',cursive;font-size:1.4rem;letter-spacing:0.05em;margin-bottom:0.4rem}
.service-item p{font-size:0.82rem;color:#666;line-height:1.7;font-weight:300}
.service-item .price{font-size:0.85rem;font-weight:700;color:#e75480;margin-top:0.8rem}

/* SPLIT ABOUT */
.about{display:grid;grid-template-columns:1fr 1fr}
@media(max-width:768px){.about{grid-template-columns:1fr}}
.about-left{background:#111;padding:4rem 3rem;display:flex;flex-direction:column;justify-content:center}
@media(max-width:768px){.about-left{padding:3rem 2rem}}
.about-left h2{font-family:'Bebas Neue',cursive;font-size:clamp(2.5rem,5vw,4rem);letter-spacing:0.03em;color:#fff;line-height:1.05;margin-bottom:1.5rem}
.about-left h2 span{color:#e75480}
.about-left p{font-size:0.85rem;color:rgba(255,255,255,0.55);line-height:1.9;font-weight:300;margin-bottom:1rem}
.about-left a{color:#e75480;font-size:0.72rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;margin-top:1rem;display:inline-block;border-bottom:1px solid #e75480;padding-bottom:2px}
.about-right{display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr}
.about-right img{width:100%;height:100%;object-fit:cover;display:block;min-height:200px}

/* PHOTO ROW */
.photo-row{display:grid;grid-template-columns:repeat(5,1fr);height:260px}
@media(max-width:768px){.photo-row{grid-template-columns:repeat(3,1fr);height:180px}}
.photo-row img{width:100%;height:100%;object-fit:cover;display:block;filter:saturate(0.9)}
.photo-row img:hover{filter:saturate(1.2)}

/* HOURS */
.hours{display:grid;grid-template-columns:1fr 1fr;border-top:2px solid #111}
@media(max-width:768px){.hours{grid-template-columns:1fr}}
.hours-left{padding:4rem 3rem;border-right:2px solid #111}
@media(max-width:768px){.hours-left{padding:3rem 2rem;border-right:none;border-bottom:2px solid #111}}
.hours-left h2{font-family:'Bebas Neue',cursive;font-size:3rem;margin-bottom:2rem;letter-spacing:0.05em}
.hour-row{display:flex;justify-content:space-between;padding:0.8rem 0;border-bottom:1px solid #eee;font-size:0.88rem}
.hour-row:last-of-type{border:none}
.hour-day{font-weight:300;color:#777}
.hour-time{font-weight:700}
.contact-item{display:flex;align-items:center;gap:0.8rem;margin-top:1.5rem;font-size:0.85rem;color:#555}
.contact-item a{color:#e75480;text-decoration:none;font-weight:700}
.hours-right{padding:4rem 3rem;background:#fafafa}
@media(max-width:768px){.hours-right{padding:3rem 2rem}}
.hours-right h2{font-family:'Bebas Neue',cursive;font-size:3rem;margin-bottom:2rem;letter-spacing:0.05em}
iframe{width:100%;height:250px;border:2px solid #111}
footer{background:#111;color:rgba(255,255,255,0.4);text-align:center;padding:2rem;font-size:0.75rem;border-top:2px solid #e75480}
footer span{color:#e75480}
</style>
</head>
<body>
<nav>
  <a href="#" class="logo">GLEN<span>SPA</span></a>
  <button class="hamburger" onclick="document.querySelector('.nav-links').classList.toggle('open')"><span></span><span></span><span></span></button>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#hours">Hours</a></li>
    <li><a href="tel:">Book Now</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="hero-bg"><img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=1600&q=80" alt="Nail salon"></div>
  <div class="hero-top-bar">
    <span>Walk-Ins Welcome</span>
    <span>Glenview, IL 60025</span>
    <span>Mon–Sun Open Daily</span>
  </div>
  <div class="hero-main">
    <div class="hero-title-block">
      <h1>Nails<br><span>Done Right.</span></h1>
      <p>Glenview's nail salon for people who care about quality. Expert technicians, premium products, zero compromise.</p>
      <div class="hero-btns">
        <a href="#services" class="btn-black">Services</a>
        <a href="#hours" class="btn-pink">Location</a>
      </div>
    </div>
  </div>
</section>

<section class="services" id="services">
  <div class="services-header">
    <h2>What We Do</h2>
    <a href="#hours">Book an Appointment →</a>
  </div>
  <div class="service-list">
    <div class="service-item"><div class="service-num">01</div><h3>Manicure</h3><p>Regular, gel, dip powder. Shaped, buffed, and polished to perfection.</p><div class="price">from $25</div></div>
    <div class="service-item"><div class="service-num">02</div><h3>Pedicure</h3><p>Soak, exfoliate, massage, and polish. Complete foot care.</p><div class="price">from $35</div></div>
    <div class="service-item"><div class="service-num">03</div><h3>Nail Art</h3><p>Chrome, ombre, hand-painted designs, gems, and more.</p><div class="price">from $15</div></div>
    <div class="service-item"><div class="service-num">04</div><h3>Acrylic Full Set</h3><p>Length, strength, and shape — done exactly how you want it.</p><div class="price">from $45</div></div>
    <div class="service-item"><div class="service-num">05</div><h3>Waxing</h3><p>Brow shaping, lip, chin, and facial waxing services.</p><div class="price">from $12</div></div>
    <div class="service-item"><div class="service-num">06</div><h3>Spa Packages</h3><p>Mani + pedi combos. The full relaxation experience.</p><div class="price">from $60</div></div>
  </div>
</section>

<section class="about" id="about">
  <div class="about-left">
    <h2>Not just a salon.<br><span>Your salon.</span></h2>
    <p>Glen Spa Nails is built around one thing: making sure you leave feeling better than when you walked in. Every technician is trained, every product is premium, and every visit is personal.</p>
    <p>Located in Glenview, IL — walk-ins always welcome, appointments preferred so we can give you our full attention.</p>
    <a href="#hours">Find Us →</a>
  </div>
  <div class="about-right">
    <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=500&q=80" alt="">
    <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=500&q=80" alt="">
    <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=500&q=80" alt="">
    <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=500&q=80" alt="">
  </div>
</section>

<div class="photo-row">
  <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=400&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=400&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=400&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=400&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=400&q=80" alt="">
</div>

<section class="hours" id="hours">
  <div class="hours-left">
    <h2>Hours</h2>
    <div class="hour-row"><span class="hour-day">Monday – Friday</span><span class="hour-time">10:00 AM – 7:30 PM</span></div>
    <div class="hour-row"><span class="hour-day">Saturday</span><span class="hour-time">9:00 AM – 6:00 PM</span></div>
    <div class="hour-row"><span class="hour-day">Sunday</span><span class="hour-time">11:00 AM – 5:00 PM</span></div>
    <div class="contact-item">📍 Glenview, IL 60025</div>
    <div class="contact-item">📞 <a href="tel:">(847) 000-0000</a></div>
    <div class="contact-item">Walk-ins welcome · Appointments preferred</div>
  </div>
  <div class="hours-right">
    <h2>Location</h2>
    <iframe src="https://www.google.com/maps/embed/v1/place?key=AIzaSyD-9tSrke72PouQMnMX-a7eZSW0jkFmBWY&q=Glenview,IL+60025" allowfullscreen loading="lazy"></iframe>
  </div>
</section>

<footer><span>Glen Spa Nails</span> · Glenview, IL · Walk-ins Welcome · © 2025</footer>
</body>
</html>
