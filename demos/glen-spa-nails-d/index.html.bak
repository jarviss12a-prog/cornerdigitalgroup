<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Glen Spa Nails | Glenview, IL</title>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;700;900&family=Inter:wght@300;400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--dark:#0d0c0e;--card:#141318;--accent:#a855f7;--accent2:#e879f9;--text:#f0eef5;--mid:#666;--border:#222}
body{font-family:'Inter',sans-serif;background:var(--dark);color:var(--text);overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1.2rem 2.5rem;background:rgba(13,12,14,0.95);backdrop-filter:blur(10px)}
.logo{font-family:'Unbounded',sans-serif;font-size:0.85rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;color:var(--text)}
.logo span{color:var(--accent)}
.nav-right{display:flex;align-items:center;gap:2.5rem}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{text-decoration:none;font-size:0.72rem;font-weight:400;letter-spacing:0.12em;text-transform:uppercase;color:var(--mid);transition:color 0.2s}
.nav-links a:hover{color:var(--text)}
.nav-book{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff !important;padding:0.5rem 1.3rem;border-radius:2px;font-weight:400}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer}
.hamburger span{width:22px;height:1px;background:var(--text)}
@media(max-width:768px){.nav-right .nav-links{display:none;position:fixed;inset:0;background:var(--dark);flex-direction:column;justify-content:center;align-items:center;gap:2rem}.nav-right .nav-links.open{display:flex}.hamburger{display:flex;z-index:200}}

/* HERO — dark with gradient blob + big text */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;position:relative;overflow:hidden;padding:2rem 2.5rem 4rem}
.hero-blob{position:absolute;top:-10%;right:-5%;width:600px;height:600px;background:radial-gradient(circle,rgba(168,85,247,0.25) 0%,rgba(232,121,249,0.1) 40%,transparent 70%);pointer-events:none}
.hero-blob2{position:absolute;bottom:10%;left:5%;width:400px;height:400px;background:radial-gradient(circle,rgba(168,85,247,0.12) 0%,transparent 60%);pointer-events:none}
.hero-img-wrap{position:absolute;top:0;right:0;height:100%;width:50%;overflow:hidden}
.hero-img-wrap img{width:100%;height:100%;object-fit:cover;opacity:0.25;mask-image:linear-gradient(to left,rgba(0,0,0,0.8),transparent)}
@media(max-width:768px){.hero-img-wrap{width:100%;opacity:0.15}}
.hero-content{position:relative;z-index:1;max-width:700px;padding-top:8rem}
.hero-eyebrow{font-family:'Unbounded',sans-serif;font-size:0.6rem;font-weight:300;letter-spacing:0.3em;text-transform:uppercase;color:var(--accent);margin-bottom:2rem;display:flex;align-items:center;gap:1rem}
.hero-eyebrow::after{content:'';flex:1;height:1px;background:var(--border)}
.hero-content h1{font-family:'Unbounded',sans-serif;font-size:clamp(2.5rem,7vw,5.5rem);font-weight:900;line-height:1.0;letter-spacing:-0.02em;margin-bottom:2rem}
.hero-content h1 span{background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-content p{font-size:1rem;color:var(--mid);max-width:450px;line-height:1.8;margin-bottom:3rem;font-weight:300}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap}
.btn-grad{display:inline-block;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;padding:1rem 2.5rem;font-size:0.75rem;font-weight:400;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;transition:opacity 0.2s}
.btn-grad:hover{opacity:0.85}
.btn-border{display:inline-block;border:1px solid var(--border);color:var(--mid);padding:1rem 2.5rem;font-size:0.75rem;font-weight:400;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;transition:all 0.2s}
.btn-border:hover{border-color:var(--accent);color:var(--text)}
.hero-bottom{display:flex;gap:3rem;margin-top:4rem;padding-top:2rem;border-top:1px solid var(--border)}
.hero-stat h3{font-family:'Unbounded',sans-serif;font-size:1.5rem;font-weight:700;color:var(--text);margin-bottom:0.2rem}
.hero-stat p{font-size:0.7rem;color:var(--mid);letter-spacing:0.15em;text-transform:uppercase}

/* SERVICES — full width table style */
.services{padding:5rem 2.5rem;border-top:1px solid var(--border)}
.services-top{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:3rem;flex-wrap:wrap;gap:1rem}
.services-top h2{font-family:'Unbounded',sans-serif;font-size:clamp(1.8rem,4vw,3rem);font-weight:700;line-height:1.1}
.services-top h2 span{color:var(--accent)}
.services-top a{font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--accent);text-decoration:none;border-bottom:1px solid var(--accent);padding-bottom:2px}
.service-row{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:2rem;padding:1.5rem 0;border-bottom:1px solid var(--border);transition:background 0.2s}
.service-row:hover{background:rgba(168,85,247,0.04)}
.service-row:last-child{border-bottom:none}
.service-row-num{font-family:'Unbounded',sans-serif;font-size:0.7rem;font-weight:300;color:var(--border);min-width:30px}
.service-row-body h3{font-family:'Unbounded',sans-serif;font-size:0.95rem;font-weight:400;margin-bottom:0.3rem}
.service-row-body p{font-size:0.8rem;color:var(--mid);line-height:1.6;font-weight:300}
.service-row-price{font-family:'Unbounded',sans-serif;font-size:0.9rem;font-weight:700;color:var(--accent);white-space:nowrap}

/* PHOTOS — horizontal strip */
.photo-strip{display:flex;gap:4px;height:300px;overflow:hidden}
.photo-strip img{flex:1;min-width:0;object-fit:cover;filter:brightness(0.7) saturate(0.8);transition:flex 0.5s,filter 0.3s}
.photo-strip img:hover{flex:3;filter:brightness(0.9) saturate(1)}
@media(max-width:768px){.photo-strip{height:180px}}

/* ABOUT — offset grid */
.about{display:grid;grid-template-columns:1fr 1fr;min-height:500px}
@media(max-width:768px){.about{grid-template-columns:1fr}}
.about-text{padding:5rem 4rem;display:flex;flex-direction:column;justify-content:center;background:var(--card)}
@media(max-width:768px){.about-text{padding:3rem 2rem}}
.about-text .tag{display:inline-block;background:rgba(168,85,247,0.15);border:1px solid rgba(168,85,247,0.3);color:var(--accent);font-size:0.65rem;font-weight:400;letter-spacing:0.25em;text-transform:uppercase;padding:0.3rem 0.8rem;margin-bottom:1.5rem;border-radius:2px}
.about-text h2{font-family:'Unbounded',sans-serif;font-size:clamp(1.5rem,3.5vw,2.5rem);font-weight:700;line-height:1.2;margin-bottom:1.5rem}
.about-text p{font-size:0.85rem;color:var(--mid);line-height:1.9;margin-bottom:1rem;font-weight:300}
.about-img{overflow:hidden}
.about-img img{width:100%;height:100%;object-fit:cover;min-height:400px;filter:brightness(0.8)}

/* HOURS */
.hours{padding:5rem 2.5rem;border-top:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr;gap:5rem}
@media(max-width:768px){.hours{grid-template-columns:1fr;gap:3rem}}
.hours h2{font-family:'Unbounded',sans-serif;font-size:clamp(1.5rem,3vw,2.2rem);font-weight:700;margin-bottom:2rem}
.hour-row{display:flex;justify-content:space-between;padding:0.9rem 0;border-bottom:1px solid var(--border);font-size:0.85rem}
.hour-row:last-of-type{border:none}
.hour-day{color:var(--mid);font-weight:300}
.hour-time{color:var(--text)}
.contact-row{display:flex;align-items:center;gap:0.8rem;padding:0.7rem 0;font-size:0.85rem;color:var(--mid)}
.contact-row a{color:var(--accent);text-decoration:none}
iframe{width:100%;height:280px;border:1px solid var(--border);filter:invert(90%) hue-rotate(180deg) brightness(0.9) saturate(0.8);margin-top:1rem}
footer{background:#080708;border-top:1px solid var(--border);text-align:center;padding:2rem;font-size:0.72rem;color:#444}
footer span{color:var(--accent)}
</style>
</head>
<body>
<nav>
  <a href="#" class="logo">Glen<span>Spa</span></a>
  <div class="nav-right">
    <button class="hamburger" onclick="document.querySelector('.nav-links').classList.toggle('open')"><span></span><span></span><span></span></button>
    <ul class="nav-links">
      <li><a href="#services">Services</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#hours">Hours</a></li>
      <li><a href="tel:" class="nav-book">Book Now</a></li>
    </ul>
  </div>
</nav>

<section class="hero">
  <div class="hero-blob"></div>
  <div class="hero-blob2"></div>
  <div class="hero-img-wrap">
    <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=1200&q=80" alt="">
  </div>
  <div class="hero-content">
    <div class="hero-eyebrow">Glenview, Illinois</div>
    <h1>Nail Art<br>That<br><span>Hits Different.</span></h1>
    <p>Premium nail care for people with taste. Walk in. Get obsessed. Come back every time.</p>
    <div class="hero-btns">
      <a href="#services" class="btn-grad">See Services</a>
      <a href="#hours" class="btn-border">Get Directions</a>
    </div>
    <div class="hero-bottom">
      <div class="hero-stat"><h3>21+</h3><p>Services offered</p></div>
      <div class="hero-stat"><h3>5★</h3><p>Avg review rating</p></div>
      <div class="hero-stat"><h3>7 Days</h3><p>Open every week</p></div>
    </div>
  </div>
</section>

<section class="services" id="services">
  <div class="services-top">
    <h2>Our<br><span>Services</span></h2>
    <a href="#hours">Book appointment →</a>
  </div>
  <div class="service-row"><span class="service-row-num">01</span><div class="service-row-body"><h3>Manicure</h3><p>Classic, gel, dip powder — shaped and polished to perfection</p></div><span class="service-row-price">from $25</span></div>
  <div class="service-row"><span class="service-row-num">02</span><div class="service-row-body"><h3>Pedicure</h3><p>Soak, exfoliate, massage, and polish — complete foot care</p></div><span class="service-row-price">from $35</span></div>
  <div class="service-row"><span class="service-row-num">03</span><div class="service-row-body"><h3>Nail Art</h3><p>Chrome, ombre, hand-painted designs, gems, florals</p></div><span class="service-row-price">from $15</span></div>
  <div class="service-row"><span class="service-row-num">04</span><div class="service-row-body"><h3>Acrylic Full Set</h3><p>Full sets and fills — the length and strength you want</p></div><span class="service-row-price">from $45</span></div>
  <div class="service-row"><span class="service-row-num">05</span><div class="service-row-body"><h3>Waxing</h3><p>Brows, lip, chin, and full facial waxing</p></div><span class="service-row-price">from $12</span></div>
  <div class="service-row"><span class="service-row-num">06</span><div class="service-row-body"><h3>Spa Package</h3><p>Mani + pedi combo — the full treatment</p></div><span class="service-row-price">from $60</span></div>
</section>

<div class="photo-strip">
  <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=500&q=80" alt="">
</div>

<section class="about" id="about">
  <div class="about-text">
    <span class="tag">About Glen Spa</span>
    <h2>We're the nail salon you've been looking for.</h2>
    <p>In Glenview, IL — Glen Spa Nails has earned a reputation for exceptional work and a relaxed, welcoming atmosphere. Our team treats every set of nails like a canvas.</p>
    <p>We use premium, safe products and maintain strict sanitation standards. Because you deserve the best — every single time.</p>
  </div>
  <div class="about-img">
    <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=800&q=80" alt="">
  </div>
</section>

<section class="hours" id="hours">
  <div>
    <h2>Hours</h2>
    <div class="hour-row"><span class="hour-day">Monday – Friday</span><span class="hour-time">10:00 AM – 7:30 PM</span></div>
    <div class="hour-row"><span class="hour-day">Saturday</span><span class="hour-time">9:00 AM – 6:00 PM</span></div>
    <div class="hour-row"><span class="hour-day">Sunday</span><span class="hour-time">11:00 AM – 5:00 PM</span></div>
    <br>
    <div class="contact-row">📍 Glenview, IL 60025</div>
    <div class="contact-row">📞 <a href="tel:">(847) 000-0000</a></div>
    <div class="contact-row">Walk-ins welcome · Appointments preferred</div>
  </div>
  <div>
    <h2>Location</h2>
    <iframe src="https://www.google.com/maps/embed/v1/place?key=AIzaSyD-9tSrke72PouQMnMX-a7eZSW0jkFmBWY&q=Glenview,IL+60025" allowfullscreen loading="lazy"></iframe>
  </div>
</section>

<footer><span>Glen Spa Nails</span> · Glenview, IL · Open 7 Days · Walk-ins Welcome · © 2025</footer>
</body>
</html>
