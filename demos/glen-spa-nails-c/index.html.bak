<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Glen Spa Nails | Glenview, IL</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Nunito+Sans:wght@300;400;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--blush:#f9eef0;--rose:#c0687a;--rose-dark:#8b3a48;--charcoal:#2d2d2d;--mid:#888}
body{font-family:'Nunito Sans',sans-serif;background:#fff;color:var(--charcoal);overflow-x:hidden}

/* NAV — centered logo style */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:#fff;border-bottom:1px solid #f0e6e8}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:1rem 2rem}
.logo{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:400;font-style:italic;text-decoration:none;color:var(--charcoal)}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{text-decoration:none;font-size:0.72rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--mid);transition:color 0.2s}
.nav-links a:hover{color:var(--rose)}
.nav-book{background:var(--rose);color:#fff !important;padding:0.5rem 1.4rem;border-radius:50px}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer}
.hamburger span{width:22px;height:1.5px;background:var(--charcoal)}
@media(max-width:768px){.nav-links{display:none;position:fixed;inset:0;background:#fff;flex-direction:column;justify-content:center;align-items:center;gap:2rem}.nav-links.open{display:flex}.hamburger{display:flex;z-index:200}}

/* HERO — centered text over full-width image */
.hero{position:relative;height:100vh;min-height:600px;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden}
.hero img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(249,238,240,0.7),rgba(249,238,240,0.85))}
.hero-content{position:relative;z-index:1;padding:0 2rem}
.hero-tag{display:inline-block;background:var(--rose);color:#fff;font-size:0.65rem;font-weight:600;letter-spacing:0.25em;text-transform:uppercase;padding:0.4rem 1.2rem;border-radius:50px;margin-bottom:1.5rem}
.hero-content h1{font-family:'Playfair Display',serif;font-size:clamp(3rem,8vw,6rem);font-weight:400;line-height:1.05;margin-bottom:1.2rem;color:var(--charcoal)}
.hero-content h1 em{font-style:italic;color:var(--rose-dark)}
.hero-content p{font-size:1rem;color:#666;max-width:480px;margin:0 auto 2.5rem;font-weight:300;line-height:1.8}
.hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.btn-rose{display:inline-block;background:var(--rose);color:#fff;padding:1rem 2.5rem;font-size:0.75rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;border-radius:50px;transition:background 0.2s}
.btn-rose:hover{background:var(--rose-dark)}
.btn-outline{display:inline-block;border:1.5px solid var(--charcoal);color:var(--charcoal);padding:1rem 2.5rem;font-size:0.75rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;border-radius:50px;transition:all 0.2s}
.btn-outline:hover{background:var(--charcoal);color:#fff}

/* RIBBON */
.ribbon{background:var(--blush);padding:1.2rem 2rem;display:flex;justify-content:center;gap:3rem;flex-wrap:wrap;border-top:1px solid #f0e0e3;border-bottom:1px solid #f0e0e3}
.ribbon-item{display:flex;align-items:center;gap:0.6rem;font-size:0.72rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--rose-dark)}

/* SERVICES — card grid with hover lift */
.services-section{padding:5rem 2rem;background:#fff}
.section-head{text-align:center;margin-bottom:3.5rem}
.section-label{font-size:0.65rem;font-weight:600;letter-spacing:0.3em;text-transform:uppercase;color:var(--rose);margin-bottom:0.7rem}
.section-head h2{font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3rem);font-weight:400}
.section-head h2 em{font-style:italic;color:var(--rose-dark)}
.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;max-width:1000px;margin:0 auto}
@media(max-width:768px){.cards{grid-template-columns:1fr 1fr}}
@media(max-width:480px){.cards{grid-template-columns:1fr}}
.card{border:1px solid #f0e6e8;padding:2.5rem 2rem;text-align:center;border-radius:8px;transition:transform 0.2s,box-shadow 0.2s;background:#fff}
.card:hover{transform:translateY(-5px);box-shadow:0 16px 40px rgba(192,104,122,0.12)}
.card-icon{font-size:2.2rem;margin-bottom:1rem}
.card h3{font-family:'Playfair Display',serif;font-size:1.15rem;margin-bottom:0.5rem}
.card p{font-size:0.82rem;color:var(--mid);line-height:1.7;font-weight:300}
.card-price{font-size:0.88rem;font-weight:700;color:var(--rose);margin-top:1rem}

/* ABOUT — full bleed with quote */
.about-band{background:var(--blush);padding:5rem 2rem;display:flex;flex-direction:column;align-items:center;text-align:center}
.about-band blockquote{font-family:'Playfair Display',serif;font-size:clamp(1.5rem,3.5vw,2.5rem);font-weight:400;font-style:italic;color:var(--rose-dark);max-width:700px;line-height:1.5;margin-bottom:2rem}
.about-band p{font-size:0.88rem;color:#777;max-width:540px;line-height:1.9;font-weight:300}

/* PHOTO BAND */
.photo-band{display:flex;height:320px;overflow:hidden}
@media(max-width:768px){.photo-band{height:200px}}
.photo-band img{flex:1;object-fit:cover;filter:saturate(0.85);transition:flex 0.4s,filter 0.3s}
.photo-band img:hover{flex:2.5;filter:saturate(1.1)}

/* HOURS */
.hours-wrap{display:grid;grid-template-columns:1fr 1fr;max-width:1100px;margin:0 auto;padding:5rem 2rem;gap:5rem}
@media(max-width:768px){.hours-wrap{grid-template-columns:1fr;gap:3rem}}
.hours-block h2{font-family:'Playfair Display',serif;font-size:2rem;font-weight:400;margin-bottom:0.3rem}
.hours-block h2 em{font-style:italic;color:var(--rose-dark)}
.hours-sub{font-size:0.78rem;color:var(--mid);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:2rem}
.hour-row{display:flex;justify-content:space-between;padding:0.8rem 0;border-bottom:1px solid #f0e6e8;font-size:0.88rem}
.hour-row:last-of-type{border:none}
.hour-day{color:var(--mid);font-weight:300}
.hour-time{font-weight:600;color:var(--charcoal)}
.contact-pill{display:inline-flex;align-items:center;gap:0.6rem;background:var(--blush);padding:0.6rem 1.2rem;border-radius:50px;font-size:0.82rem;font-weight:600;margin-top:0.7rem;margin-right:0.5rem;text-decoration:none;color:var(--charcoal)}
.contact-pill span{font-size:1rem}
iframe{width:100%;height:280px;border:1px solid #f0e6e8;border-radius:8px;margin-top:1.5rem}
footer{background:var(--charcoal);text-align:center;padding:2.5rem;font-size:0.75rem;color:rgba(255,255,255,0.4)}
footer span{color:var(--rose)}
</style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a href="#" class="logo">Glen Spa Nails</a>
    <button class="hamburger" onclick="document.querySelector('.nav-links').classList.toggle('open')"><span></span><span></span><span></span></button>
    <ul class="nav-links">
      <li><a href="#services">Services</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#hours">Hours</a></li>
      <li><a href="tel:" class="nav-book">Book Now</a></li>
    </ul>
  </div>
</nav>

<section class="hero">
  <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=1600&q=80" alt="Nail salon">
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-tag">Glenview's Favorite Nail Salon</div>
    <h1>Beautiful nails.<br><em>Happy you.</em></h1>
    <p>A warm, welcoming nail spa where you come to relax, recharge, and leave looking gorgeous.</p>
    <div class="hero-btns">
      <a href="#services" class="btn-rose">View Services</a>
      <a href="#hours" class="btn-outline">Find Us</a>
    </div>
  </div>
</section>

<div class="ribbon">
  <div class="ribbon-item">🌸 Premium Products</div>
  <div class="ribbon-item">💅 Expert Technicians</div>
  <div class="ribbon-item">✨ Walk-Ins Welcome</div>
  <div class="ribbon-item">🎁 Gift Cards Available</div>
</div>

<section class="services-section" id="services">
  <div class="section-head">
    <p class="section-label">What We Offer</p>
    <h2>Our <em>Services</em></h2>
  </div>
  <div class="cards">
    <div class="card"><div class="card-icon">💅</div><h3>Manicure</h3><p>Regular, gel, dip powder, and more — perfectly shaped every time.</p><div class="card-price">from $25</div></div>
    <div class="card"><div class="card-icon">🦶</div><h3>Pedicure</h3><p>Relaxing soak, scrub, massage, and polish. Leave with silky feet.</p><div class="card-price">from $35</div></div>
    <div class="card"><div class="card-icon">🎨</div><h3>Nail Art</h3><p>Chrome, ombre, florals, gems — tell us your vision, we'll create it.</p><div class="card-price">from $15</div></div>
    <div class="card"><div class="card-icon">💎</div><h3>Acrylic & Gel</h3><p>Full sets, fills, and extensions for strength and length.</p><div class="card-price">from $45</div></div>
    <div class="card"><div class="card-icon">✨</div><h3>Waxing</h3><p>Brow shaping, lip, chin, and full facial waxing.</p><div class="card-price">from $12</div></div>
    <div class="card"><div class="card-icon">🌺</div><h3>Spa Packages</h3><p>Mani + pedi combos for the full spa experience.</p><div class="card-price">from $60</div></div>
  </div>
</section>

<div class="about-band" id="about">
  <blockquote>"Every client deserves to feel beautiful — that's not just our motto, it's how we work."</blockquote>
  <p>Glen Spa Nails has been Glenview's go-to nail spa for years. Our skilled team uses only premium, safe products and keeps the highest sanitation standards — so you can relax, knowing you're in good hands.</p>
  <br>
  <a href="#hours" class="btn-rose" style="margin-top:1.5rem">Come Visit Us</a>
</div>

<div class="photo-band">
  <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=500&q=80" alt="">
  <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=500&q=80" alt="">
</div>

<div id="hours">
  <div class="hours-wrap">
    <div class="hours-block">
      <h2>Hours &<br><em>Location</em></h2>
      <p class="hours-sub">Open 7 days · Walk-ins welcome</p>
      <div class="hour-row"><span class="hour-day">Monday – Friday</span><span class="hour-time">10:00 AM – 7:30 PM</span></div>
      <div class="hour-row"><span class="hour-day">Saturday</span><span class="hour-time">9:00 AM – 6:00 PM</span></div>
      <div class="hour-row"><span class="hour-day">Sunday</span><span class="hour-time">11:00 AM – 5:00 PM</span></div>
      <div style="margin-top:2rem">
        <a href="#" class="contact-pill"><span>📍</span> Glenview, IL 60025</a>
        <a href="tel:" class="contact-pill"><span>📞</span> (847) 000-0000</a>
      </div>
    </div>
    <div class="hours-block">
      <h2>Find<br><em>Us</em></h2>
      <p class="hours-sub">Come in — we'd love to see you</p>
      <iframe src="https://www.google.com/maps/embed/v1/place?key=AIzaSyD-9tSrke72PouQMnMX-a7eZSW0jkFmBWY&q=Glenview,IL+60025" allowfullscreen loading="lazy"></iframe>
    </div>
  </div>
</div>

<footer><span>Glen Spa Nails</span> · Glenview, IL · Walk-ins Welcome · Gift Cards Available · © 2025</footer>
</body>
</html>
